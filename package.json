{
  "name": "react-chord-diagram",
  "version": "3.0.0",
  "description": "A React component for building D3 Chord Diagrams",
  "main": "dist/react-chord-diagram.cjs",
  "module": "dist/react-chord-diagram.js",
  "exports": {
    ".": {
      "import": "./dist/react-chord-diagram.js",
      "require": "./dist/react-chord-diagram.cjs",
      "default": "./dist/react-chord-diagram.js"
    },
    "./style.css": "./dist/react-chord-diagram.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "vite demo",
    "build": "vite build",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-chord": "^3.0.1",
    "d3-color": "^3.1.0",
    "d3-format": "^3.1.2",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "prop-types": "^15.8.1"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rimraf": "^6.1.3",
    "vite": "^8.0.10"
  },
  "author": "Grayson Langford",
  "homepage": "https://github.com/langfordG/react-chord-diagram#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/langfordG/react-chord-diagram.git"
  },
  "bugs": {
    "url": "https://github.com/langfordG/react-chord-diagram/issues"
  },
  "keywords": [
    "react",
    "chord-diagram",
    "d3",
    "react-component"
  ]
}
